[user]
    name = Jeremy Jackson
    useConfigOnly = true

[includeIf "gitdir:~/dev/personal/"]
    path = ~/dotfiles/git/.gitconfig-personal

[includeIf "gitdir:~/dotfiles/"]
    path = ~/dotfiles/git/.gitconfig-personal

[includeIf "gitdir:~/dev/work/"]
    path = ~/dotfiles/git/.gitconfig-work

[core]
	editor = nvim

[credential]
    helper = store

[pull]
	rebase = false

[init]
	defaultbranch = main
